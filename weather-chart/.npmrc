# NPM Configuration - LOCAL PROJECT CONFIG
# This file overrides ~/.npmrc settings for this project only

# Force this config to be used (ignore parent/global configs for certain settings)
# Registry - use official npm registry
registry=https://registry.npmjs.org/

# Explicitly set auth settings to avoid inheriting from global config
//registry.npmjs.org/:_authToken=

# Package management settings
save-exact=false
legacy-peer-deps=false

# Audit settings
audit=true
audit-level=moderate

# Cache settings - use project-specific cache
cache=./npm-cache

# Progress bar
progress=true

# Verbose logging
loglevel=warn

